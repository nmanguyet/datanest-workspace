import os
import sys
from datetime import datetime, timedelta

from pyspark.sql import functions as F

from etl.common.init_spark3 import setup
from etl.common.utils import check_multi_date_count, check_data_date
from etl.vnpt.spark_config import medium_config

if len(sys.argv) != 2:
    print('need processing date string: python {} YYYY-mm-dd'.format(sys.argv[0]), file=sys.stderr)
    exit(1)

curdate_str = sys.argv[1]
curdate = datetime.strptime(curdate_str, "%Y-%m-%d")
weekday = curdate.weekday()
this_sunday = curdate - timedelta(weekday - 6)

# if not check_multi_date_count('balance', this_sunday, 60, DAILY_COUNT_THRESHOLD=0.1):
#     exit(1)

spark = setup(job_cfg=medium_config(), script_name="airflow_top1_location_30d")

in_dir = "/data/vnpt_v2/balance"
out_dir = "/data/processed/credit_score_v1.2/features/balance/agg/60days"
lad_dir = "/data/processed/credit_score_v1.2/features/sub/last_activated_date/weekly"

def compute(agg_date, in_dir, out_dir, lad_dir, backward_days=60):
    start_date = (agg_date - timedelta(days=backward_days - 1))
    out_file = os.path.join(out_dir, "date={}".format(agg_date.strftime("%Y-%m-%d")))
    lad_file = os.path.join(lad_dir, "date={}".format(agg_date.strftime("%Y-%m-%d")))
    print(start_date, agg_date, out_file, lad_file)
    lad_df = spark.read.parquet(lad_file)
    df = spark.read.format('delta').load(in_dir)

    df = df.select("phone_number", "balance", "date", "account_code") \
        .filter(df.date > start_date) \
        .filter(df.date <= agg_date)

    check_data_date(spark, df, int((agg_date - start_date).days),
                    path=in_dir, start_date=start_date + timedelta(days=1), end_date=agg_date)

    df = df.filter(~(df.account_code.startswith('3'))) \
        .filter(~(df.account_code.contains("142"))) \
        .filter("balance >= 0") \
        .groupBy("phone_number", "date").agg(F.sum("balance").alias("balance")) \
        .join(lad_df, "phone_number") \
        .filter("date >= last_activated_date") \
        .select("phone_number", "balance")
    df.cache()
    df.count()

    ft_stat = df.groupBy("phone_number") \
        .agg(
            F.avg("balance").alias("balance_avg_per_day"),
            F.max("balance").alias("balance_max_per_day"),
            F.stddev("balance").alias("balance_sd_per_day")
        )
    ft_stat.cache()
    ft_stat.count()

    ft_balance = df.withColumn("lt_1k", F.when((F.col("balance") > 0) & (F.col("balance") < 1000), 1).otherwise(0)) \
        .withColumn("lt_5k", F.when((F.col("balance") > 0) & (F.col("balance") < 5000), 1).otherwise(0)) \
        .withColumn("lt_10k", F.when((F.col("balance") > 0) & (F.col("balance") < 10000), 1).otherwise(0)) \
        .withColumn("is_zero", F.when(F.col("balance") == 0, 1).otherwise(0)) \
        .withColumn("ge_1k_lt_5k", F.when((F.col("balance") >= 1000) & (F.col("balance") < 5000), 1).otherwise(0)) \
        .withColumn("ge_5k_lt_10k", F.when((F.col("balance") >= 5000) & (F.col("balance") < 10000), 1).otherwise(0)) \
        .withColumn("ge_10k_lt_20k", F.when((F.col("balance") >= 10000) & (F.col("balance") < 20000), 1).otherwise(0)) \
        .withColumn("ge_20k_lt_5k", F.when((F.col("balance") >= 20000) & (F.col("balance") < 50000), 1).otherwise(0)) \
        .withColumn("ge_50k_lt_100k", F.when((F.col("balance") >= 50000) & (F.col("balance") < 100000), 1).otherwise(0)) \
        .withColumn("ge_100k", F.when(F.col("balance") >= 100000, 1).otherwise(0)) \
        .groupBy("phone_number") \
        .agg(
            F.mean("lt_1k").alias("balance_pct_day_lt_1k"),
            F.mean("lt_5k").alias("balance_pct_day_lt_5k"),
            F.mean("lt_10k").alias("balance_pct_day_lt_10k"),
            F.mean("is_zero").alias("balance_pct_day_zero"),
            F.mean("ge_1k_lt_5k").alias("balance_pct_day_1k_to_5k"),
            F.mean("ge_5k_lt_10k").alias("balance_pct_day_5k_to_10k"),
            F.mean("ge_10k_lt_20k").alias("balance_pct_day_10k_to_20k"),
            F.mean("ge_20k_lt_5k").alias("balance_pct_day_20k_to_50k"),
            F.mean("ge_50k_lt_100k").alias("balance_pct_day_50k_to_100k"),
            F.mean("ge_100k").alias("balance_pct_day_ge_100k")
        )
    ft_balance.cache()
    ft_balance.count()

    ft = ft_stat.join(ft_balance, "phone_number", "outer").fillna(0)

    ft.write.format("parquet") \
        .mode("overwrite") \
        .option("compression", "snappy") \
        .save(out_file)

    df.unpersist()
    ft_balance.unpersist()
    ft_stat.unpersist()

compute(this_sunday, in_dir, out_dir, lad_dir)
